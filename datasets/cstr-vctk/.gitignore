### Build artefacts ###
# Generated by convert.py; contains the audformat database files and all
# flattened audio files ready for audb.publish.
build/

### Raw / extracted dataset files ###
# Large binary data - obtain via download-from_nas.sh or download-from_web.sh.
data/raw/
data/extracted/
# Intermediate flat copy produced by older versions of convert.py (superseded
# by build/flac/).
data/flac/

